# ——— Instance Configuration ———
# Each clone/instance MUST have a unique COMPOSE_PROJECT_NAME and APP_PORT.
# This avoids port conflicts when running multiple instances simultaneously.
#
# Example setups:
#   Instance 1: COMPOSE_PROJECT_NAME=app1  APP_PORT=80
#   Instance 2: COMPOSE_PROJECT_NAME=app2  APP_PORT=8080
#   Instance 3: COMPOSE_PROJECT_NAME=app3  APP_PORT=8082
#
COMPOSE_PROJECT_NAME=app
APP_PORT=8080

# ——— Service Versions ———
PHP_VERSION=8.3
MYSQL_VERSION=8.4
POSTGRES_VERSION=16
MONGO_VERSION=7
REDIS_VERSION=7
RABBITMQ_VERSION=4.0.6

# ——— Xdebug ———
XDEBUG_MODE=off

# ——— MySQL ———
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app_db
MYSQL_USER=app
MYSQL_PASSWORD=app

# ——— PostgreSQL ———
POSTGRES_DB=app_db
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# ——— MongoDB ———
MONGO_INITDB_DATABASE=app_db
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root

# ——— Redis ———
# REDIS_PASSWORD=secret

# ——— Exposed Ports ———
# Change these if they conflict with other services on your host.
# When running multiple instances, each must use unique ports.
MYSQL_PORT=3306
MYSQL_TEST_PORT=3307
POSTGRES_PORT=5432
POSTGRES_TEST_PORT=15432
MONGO_PORT=27017
MONGO_TEST_PORT=27018
REDIS_PORT=6379
ADMINER_PORT=8081
PORT_MAIL_SMTP=1025
PORT_MAIL_HTTP=8025
PORT_RABBITMQ_LISTENER=5672
PORT_RABBITMQ_TCP_LISTENER=5673
PORT_RABBITMQ_MANAGEMENT=15672
